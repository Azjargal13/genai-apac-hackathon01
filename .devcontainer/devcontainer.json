{
  "name": "Energy Task Manager",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "containerEnv": {
    "PYTHONPATH": "${containerWorkspaceFolder}/src"
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  },
  "postCreateCommand": "pip3 install --user -r requirements.txt",
  "forwardPorts": [8080, 8000, 55555],
  "portsAttributes": {
    "8080": { "label": "FastAPI / Cloud Run local" },
    "8000": { "label": "ADK web (optional)" },
    "55555": { "label": "OAuth redirect (google_oauth_login.py)" }
  }
}

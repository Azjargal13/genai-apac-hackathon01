# Copy to `.env` (gitignored). On Cloud Run, set the same names via Secret Manager / service env.

# --- Google Cloud / Firestore ---
GOOGLE_CLOUD_PROJECT=
FIRESTORE_DATABASE_ID=(default)
# Local / Codespaces: path to service account JSON (Cloud Run uses the runtime SA instead)
# GOOGLE_APPLICATION_CREDENTIALS=/workspaces/<repo>/secrets/firebase-sa.json

# --- App defaults (optional; API can send X-User-Id / X-Session-Id) ---
DEFAULT_USER_ID=
DEFAULT_SESSION_ID=

# --- ADK / Gemini (see Google ADK docs for your setup) ---
# ADK_MODEL=gemini-3-flash-preview
# Cap reply length + steady outputs (helps cost / rate limits). Lower = shorter replies.
# ADK_MAX_OUTPUT_TOKENS=1024
# ADK_TEMPERATURE=0.45
# GOOGLE_GENAI_USE_VERTEXAI=
# VERTEXAI_LOCATION=
# GOOGLE_API_KEY=

# --- Google Tasks + Calendar (user OAuth; not the Firestore SA) ---
# Desktop client JSON + python scripts/google_oauth_login.py — paste redirect URL from browser (see COMMANDS.md).
# OAuth consent "Testing" + Test users for solo demo. OAUTH_LOCAL_SERVER=1 = loopback server instead of paste.
# GOOGLE_OAUTH_CLIENT_SECRETS_PATH=secrets/oauth-client.json
# Local / Codespaces: file written by the script
# GOOGLE_OAUTH_TOKEN_PATH=secrets/token.json
# Cloud Run: Secret Manager → full token.json body as this env (takes precedence over file)
# GOOGLE_OAUTH_TOKEN_JSON=
# GOOGLE_TASKS_DEFAULT_LIST_ID=@default
# IANA timezone for Calendar event dateTime (default in code: Asia/Ulaanbaatar)
# GOOGLE_CALENDAR_TIMEZONE=Asia/Ulaanbaatar

# --- Optional ---
# REGION=asia-northeast3

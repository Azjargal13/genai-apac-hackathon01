# Copy to .env for local development. On Cloud Run, use Secret Manager / service env vars.

# Google Cloud
GOOGLE_CLOUD_PROJECT=

# Gemini / Vertex (names depend on ADK / SDK version — align with your ADK docs)
# GOOGLE_GENAI_USE_VERTEXAI=
# VERTEXAI_LOCATION=

# Optional: explicit API key path for local only (prefer ADC on Cloud Run)
# GOOGLE_API_KEY=

# Google Calendar API (OAuth or service account — document which you use)
# CALENDAR_CREDENTIALS_PATH=

# REGION=asia-northeast3 //seoul region

